---
import DrawingSheet from '../layouts/DrawingSheet.astro';
---

<DrawingSheet
  title="Hollow — An engineering company"
  description="Hollow Technologies Pty Ltd — an engineering company based in Australia."
>
  <!-- nav -->
  <nav class="nav" style="justify-content:flex-end">
    <div style="display:flex;align-items:center;gap:20px">
      <span style="font:500 11px 'Spline Sans Mono',monospace;letter-spacing:.16em;color:var(--muted)">AUSTRALIA</span>
      <button class="tbtn" onclick="toggleTheme()" aria-label="Toggle light and dark">THEME</button>
    </div>
  </nav>

  <!-- hero: dimensioned mark -->
  <div class="stage">
    <div class="drawing" style="--w:380;--h:320">
      <img src="/assets/logo_icon_black.svg" alt="" style="position:absolute;left:120px;top:78px;width:130px;display:block;opacity:.95;filter:invert(var(--invert))" />
      <svg viewBox="0 0 380 320" style="position:absolute;inset:0;width:100%;height:100%">
        <g stroke="currentColor" stroke-width="1" stroke-opacity=".55" fill="none">
          <!-- vertical dimension (left) -->
          <line x1="116" y1="78" x2="60" y2="78"/>
          <line x1="116" y1="226" x2="60" y2="226"/>
          <line x1="74" y1="78" x2="74" y2="226"/>
          <!-- horizontal dimension (bottom) -->
          <line x1="120" y1="230" x2="120" y2="272"/>
          <line x1="250" y1="230" x2="250" y2="272"/>
          <line x1="120" y1="258" x2="250" y2="258"/>
          <!-- leader -->
          <line x1="250" y1="120" x2="300" y2="96"/>
          <line x1="300" y1="96" x2="338" y2="96"/>
        </g>
        <g fill="currentColor" fill-opacity=".6">
          <polygon points="70,88 74,78 78,88"/>
          <polygon points="70,216 74,226 78,216"/>
          <polygon points="130,254 120,258 130,262"/>
          <polygon points="240,254 250,258 240,262"/>
          <circle cx="250" cy="120" r="2"/>
        </g>
      </svg>
      <!-- dimension labels -->
      <span style="position:absolute;left:20px;top:152px;transform:translateY(-50%) rotate(-90deg);white-space:nowrap;font:500 8.5px/1.5 'Spline Sans Mono',monospace;color:var(--muted);text-align:center">[2.520]<br>64.00</span>
      <span style="position:absolute;left:120px;width:130px;top:280px;text-align:center;font:500 8.5px/1.5 'Spline Sans Mono',monospace;color:var(--muted)">[2.008]<br>51.00</span>
      <span style="position:absolute;left:300px;top:82px;font:500 8.5px 'Spline Sans Mono',monospace;letter-spacing:.1em;color:var(--muted)">REV X1</span>
    </div>
    <p class="tagline">An engineering company.</p>
  </div>

  <!-- products (bottom-left) -->
  <div class="corner-left work" style="flex-direction:column;gap:14px">
    <span style="font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.26em;color:var(--muted)">WORK</span>
    <div class="links" data-linkstyle="button" data-linklayout="horizontal" style="display:flex;gap:12px">
      <a class="pbtn" href="/plate-connect/">PLATE + CONNECT</a>
      <a class="pbtn" href="/drive/">DRIVE</a>
    </div>
  </div>

  <!-- title block (bottom-right) -->
  <div class="titleblock">
    <div style="padding:9px 13px;border-bottom:1px solid var(--frame);font:600 12px 'Outfit',sans-serif;letter-spacing:.02em;color:var(--fg)">HOLLOW TECHNOLOGIES PTY LTD</div>
    <div style="display:flex;border-bottom:1px solid var(--frame)">
      <span style="padding:7px 13px;border-right:1px solid var(--frame);font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.14em;color:var(--muted);width:52px">TITLE</span>
      <span style="padding:7px 13px;flex:1;font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.14em;color:var(--fg)">PRESENCE</span>
    </div>
    <div style="display:flex;border-bottom:1px solid var(--frame)">
      <span style="padding:7px 13px;border-right:1px solid var(--frame);font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.1em;color:var(--muted);flex:1">SIZE&nbsp;&nbsp;D</span>
      <span style="padding:7px 13px;border-right:1px solid var(--frame);font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.1em;color:var(--muted);flex:1">SCALE&nbsp;&nbsp;1:1</span>
      <span style="padding:7px 13px;font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.1em;color:var(--muted);flex:1.2">SHEET 1 OF 1</span>
    </div>
    <div style="display:flex;align-items:center;justify-content:space-between;padding:7px 13px">
      <span style="font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.08em;color:var(--muted)">ABN 75 679 196 993</span>
      <a href="mailto:hello@hollow.rs" style="font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.08em;color:var(--fg)">hello@hollow.rs</a>
    </div>
  </div>
</DrawingSheet>
