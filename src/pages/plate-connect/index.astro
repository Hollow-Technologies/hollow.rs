---
import DrawingSheet from '../../layouts/DrawingSheet.astro';
---

<DrawingSheet
  title="Plate + Connect — Hollow"
  description="Plate + Connect — a connected system by Hollow Technologies Pty Ltd."
>
  <!-- nav -->
  <nav class="nav" style="justify-content:space-between">
    <a href="/" style="display:block"><img src="/assets/logo_horizontal_black.svg" alt="Hollow" style="height:51px;display:block;filter:invert(var(--invert))" /></a>
    <div style="display:flex;align-items:center;gap:20px">
      <span style="font:500 11px 'Spline Sans Mono',monospace;letter-spacing:.16em;color:var(--muted)">AUSTRALIA</span>
      <button class="tbtn" onclick="toggleTheme()" aria-label="Toggle light and dark">THEME</button>
    </div>
  </nav>

  <!-- center: name + technical drawing -->
  <div class="stage">
    <div style="text-align:center;display:flex;flex-direction:column;gap:13px">
      <span style="font:500 11px 'Spline Sans Mono',monospace;letter-spacing:.24em;color:var(--muted)">01 · CONNECTED SYSTEM</span>
      <h1 class="h-title">Plate<span style="color:var(--muted)"> + </span>Connect</h1>
    </div>

    <div class="drawing d-wide" style="--w:520;--h:250">
      <svg viewBox="0 0 520 250" style="position:absolute;inset:0;width:100%;height:100%">
        <!-- plate outline -->
        <g stroke="currentColor" stroke-width="1.4" stroke-opacity=".85" fill="none">
          <rect x="34" y="52" width="322" height="132" rx="7"/>
          <rect x="48" y="66" width="294" height="104" rx="4" stroke-opacity=".4"/>
          <rect x="356" y="104" width="9" height="28" rx="2"/>
        </g>
        <!-- mounting holes + crosshair -->
        <g stroke="currentColor" stroke-width="1.1" stroke-opacity=".7" fill="none">
          <circle cx="58" cy="76" r="6.5"/><circle cx="332" cy="76" r="6.5"/><circle cx="58" cy="160" r="6.5"/><circle cx="332" cy="160" r="6.5"/>
          <line x1="58" y1="66" x2="58" y2="86"/><line x1="48" y1="76" x2="68" y2="76"/>
          <line x1="332" y1="66" x2="332" y2="86"/><line x1="322" y1="76" x2="342" y2="76"/>
          <line x1="58" y1="150" x2="58" y2="170"/><line x1="48" y1="160" x2="68" y2="160"/>
          <line x1="332" y1="150" x2="332" y2="170"/><line x1="322" y1="160" x2="342" y2="160"/>
        </g>
        <!-- phone (Connect) -->
        <g stroke="currentColor" stroke-width="1.4" stroke-opacity=".85" fill="none">
          <rect x="436" y="52" width="62" height="152" rx="15"/>
          <rect x="443" y="64" width="48" height="128" rx="9" stroke-opacity=".4"/>
        </g>
        <g stroke="currentColor" stroke-width="1.1" stroke-opacity=".5" fill="none">
          <rect x="452" y="98" width="30" height="17" rx="3"/>
          <line x1="452" y1="128" x2="482" y2="128"/>
          <line x1="452" y1="140" x2="474" y2="140"/>
        </g>
        <g fill="currentColor" fill-opacity=".55">
          <rect x="456" y="70" width="22" height="5.5" rx="2.75"/>
          <rect x="457" y="183" width="20" height="3" rx="1.5"/>
        </g>
        <!-- BLE link -->
        <g stroke="currentColor" stroke-width="1.2" stroke-opacity=".55" fill="none" stroke-dasharray="4 4">
          <path d="M365,118 C400,118 415,124 436,124"/>
        </g>
        <!-- width dimension -->
        <g stroke="currentColor" stroke-width="1" stroke-opacity=".45" fill="none">
          <line x1="34" y1="196" x2="34" y2="228"/>
          <line x1="356" y1="196" x2="356" y2="228"/>
          <line x1="34" y1="218" x2="356" y2="218"/>
        </g>
        <g fill="currentColor" fill-opacity=".55">
          <polygon points="44,214 34,218 44,222"/>
          <polygon points="346,214 356,218 346,222"/>
        </g>
      </svg>
      <span style="position:absolute;left:34px;width:322px;top:225px;text-align:center;font:500 8.5px/1.5 'Spline Sans Mono',monospace;color:var(--muted)">[XX.XX]<br>DIM. TBD</span>
      <span style="position:absolute;left:48px;width:294px;top:75px;text-align:center;font:500 8px 'Spline Sans Mono',monospace;letter-spacing:.42em;color:var(--muted)">AUSTRALIA</span>
      <span style="position:absolute;left:48px;width:294px;top:118px;transform:translateY(-50%);text-align:center;font:600 46px 'Spline Sans Mono',monospace;letter-spacing:.06em;color:var(--fg)">H0LL0W</span>
      <span style="position:absolute;left:34px;top:36px;font:500 8.5px 'Spline Sans Mono',monospace;letter-spacing:.18em;color:var(--muted)">PLATE</span>
      <span style="position:absolute;left:432px;top:36px;font:500 8.5px 'Spline Sans Mono',monospace;letter-spacing:.18em;color:var(--muted)">CONNECT</span>
      <span style="position:absolute;left:388px;top:96px;font:500 8px 'Spline Sans Mono',monospace;letter-spacing:.16em;color:var(--muted)">BLE</span>
    </div>
  </div>

  <!-- bottom-left nav -->
  <div class="links corner-left" data-linkstyle="button" data-linklayout="horizontal" style="align-items:center;gap:16px">
    <a href="/" class="nlink">← INDEX</a>
    <span class="sep" style="color:var(--muted);opacity:.4">·</span>
    <a href="/drive/" class="nlink">DRIVE ↗</a>
  </div>

  <!-- title block -->
  <div class="titleblock">
    <div style="padding:9px 13px;border-bottom:1px solid var(--frame);font:600 12px 'Outfit',sans-serif;letter-spacing:.02em;color:var(--fg)">HOLLOW TECHNOLOGIES PTY LTD</div>
    <div style="display:flex;border-bottom:1px solid var(--frame)">
      <span style="padding:7px 13px;border-right:1px solid var(--frame);font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.14em;color:var(--muted);width:52px">TITLE</span>
      <span style="padding:7px 13px;flex:1;font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.14em;color:var(--fg)">PLATE + CONNECT</span>
    </div>
    <div style="display:flex;border-bottom:1px solid var(--frame)">
      <span style="padding:7px 13px;border-right:1px solid var(--frame);font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.1em;color:var(--muted);flex:1">SIZE&nbsp;&nbsp;D</span>
      <span style="padding:7px 13px;border-right:1px solid var(--frame);font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.1em;color:var(--muted);flex:1">SCALE&nbsp;&nbsp;1:2</span>
      <span style="padding:7px 13px;font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.1em;color:var(--muted);flex:1.2">SHEET 1 OF 1</span>
    </div>
    <div style="display:flex;align-items:center;justify-content:space-between;padding:7px 13px">
      <span style="font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.08em;color:var(--muted)">DWG&nbsp;&nbsp;HC-001</span>
      <a href="mailto:hello@hollow.rs" style="font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.08em;color:var(--fg)">hello@hollow.rs</a>
    </div>
  </div>
</DrawingSheet>
