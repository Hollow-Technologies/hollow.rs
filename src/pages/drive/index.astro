---
import DrawingSheet from '../../layouts/DrawingSheet.astro';
---

<DrawingSheet
  title="Drive — Hollow"
  description="Drive — motor control by Hollow Technologies Pty Ltd."
>
  <!-- nav -->
  <nav class="nav" style="justify-content:space-between">
    <a href="/" style="display:block"><img src="/assets/logo_horizontal_black.svg" alt="Hollow" style="height:51px;display:block;filter:invert(var(--invert))" /></a>
    <div style="display:flex;align-items:center;gap:20px">
      <span style="font:500 11px 'Spline Sans Mono',monospace;letter-spacing:.16em;color:var(--muted)">AUSTRALIA</span>
      <button class="tbtn" onclick="toggleTheme()" aria-label="Toggle light and dark">THEME</button>
    </div>
  </nav>

  <!-- center: name + technical drawing -->
  <div class="stage">
    <div style="text-align:center;display:flex;flex-direction:column;gap:13px">
      <span style="font:500 11px 'Spline Sans Mono',monospace;letter-spacing:.24em;color:var(--muted)">02 · MOTOR CONTROL</span>
      <h1 class="h-title">Drive</h1>
    </div>

    <div class="drawing d-wide" style="--w:520;--h:262">
      <svg viewBox="0 0 520 262" style="position:absolute;inset:0;width:100%;height:100%">
        <!-- board + main features -->
        <g stroke="currentColor" stroke-width="1.4" stroke-opacity=".85" fill="none">
          <rect x="70" y="26" width="260" height="200" rx="6"/>
          <rect x="118" y="40" width="32" height="12" rx="1.5"/>
          <rect x="172" y="40" width="32" height="12" rx="1.5"/>
          <rect x="226" y="40" width="32" height="12" rx="1.5"/>
          <circle cx="130" cy="170" r="22"/><circle cx="190" cy="170" r="22"/><circle cx="250" cy="170" r="22"/>
          <rect x="398" y="90" width="62" height="56" rx="11"/>
          <line x1="460" y1="118" x2="500" y2="118" stroke-width="2.4"/><rect x="500" y="112" width="10" height="12" rx="1.5"/>
        </g>
        <g stroke="currentColor" stroke-width="1.1" stroke-opacity=".55" fill="none">
          <circle cx="130" cy="170" r="13"/><circle cx="190" cy="170" r="13"/><circle cx="250" cy="170" r="13"/>
          <rect x="256" y="74" width="30" height="30" rx="2"/>
          <rect x="150" y="98" width="20" height="20" rx="2"/>
          <rect x="196" y="100" width="14" height="14" rx="2"/>
        </g>
        <!-- motor fins + feet -->
        <g stroke="currentColor" stroke-width="1.1" stroke-opacity=".45" fill="none">
          <line x1="410" y1="95" x2="410" y2="141"/>
          <line x1="421" y1="95" x2="421" y2="141"/>
          <line x1="432" y1="95" x2="432" y2="141"/>
          <line x1="443" y1="95" x2="443" y2="141"/>
          <rect x="404" y="146" width="13" height="6" rx="1"/>
          <rect x="441" y="146" width="13" height="6" rx="1"/>
        </g>
        <!-- mounting holes -->
        <g stroke="currentColor" stroke-width="1.1" stroke-opacity=".7" fill="none">
          <circle cx="94" cy="50" r="6.5"/><circle cx="306" cy="50" r="6.5"/><circle cx="94" cy="202" r="6.5"/><circle cx="306" cy="202" r="6.5"/>
          <line x1="94" y1="40" x2="94" y2="60"/><line x1="84" y1="50" x2="104" y2="50"/>
          <line x1="306" y1="40" x2="306" y2="60"/><line x1="296" y1="50" x2="316" y2="50"/>
          <line x1="94" y1="192" x2="94" y2="212"/><line x1="84" y1="202" x2="104" y2="202"/>
          <line x1="306" y1="192" x2="306" y2="212"/><line x1="296" y1="202" x2="316" y2="202"/>
        </g>
        <!-- 3-phase leads -->
        <g stroke="currentColor" stroke-width="1.3" stroke-opacity=".6" fill="none">
          <polyline points="330,92 366,92 366,104 398,104"/>
          <polyline points="330,116 398,116"/>
          <polyline points="330,140 366,140 366,128 398,128"/>
        </g>
        <!-- width dimension -->
        <g stroke="currentColor" stroke-width="1" stroke-opacity=".45" fill="none">
          <line x1="70" y1="230" x2="70" y2="252"/>
          <line x1="330" y1="230" x2="330" y2="252"/>
          <line x1="70" y1="243" x2="330" y2="243"/>
        </g>
        <g fill="currentColor" fill-opacity=".55">
          <polygon points="80,239 70,243 80,247"/>
          <polygon points="320,239 330,243 320,247"/>
        </g>
      </svg>
      <span style="position:absolute;left:70px;width:260px;top:250px;text-align:center;font:500 8.5px/1.5 'Spline Sans Mono',monospace;color:var(--muted)">[XX.XX] DIM. TBD</span>
      <span style="position:absolute;left:398px;width:62px;top:157px;text-align:center;font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.14em;color:var(--muted)">M&nbsp;&nbsp;3~</span>
      <span style="position:absolute;left:336px;top:76px;font:500 8px 'Spline Sans Mono',monospace;letter-spacing:.16em;color:var(--muted)">3&#216;</span>
    </div>
  </div>

  <!-- bottom-left nav -->
  <div class="links corner-left" data-linkstyle="button" data-linklayout="horizontal" style="align-items:center;gap:16px">
    <a href="/" class="nlink">← INDEX</a>
    <span class="sep" style="color:var(--muted);opacity:.4">·</span>
    <a href="/plate-connect/" class="nlink">PLATE + CONNECT ↗</a>
  </div>

  <!-- title block -->
  <div class="titleblock">
    <div style="padding:9px 13px;border-bottom:1px solid var(--frame);font:600 12px 'Outfit',sans-serif;letter-spacing:.02em;color:var(--fg)">HOLLOW TECHNOLOGIES PTY LTD</div>
    <div style="display:flex;border-bottom:1px solid var(--frame)">
      <span style="padding:7px 13px;border-right:1px solid var(--frame);font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.14em;color:var(--muted);width:52px">TITLE</span>
      <span style="padding:7px 13px;flex:1;font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.14em;color:var(--fg)">DRIVE</span>
    </div>
    <div style="display:flex;border-bottom:1px solid var(--frame)">
      <span style="padding:7px 13px;border-right:1px solid var(--frame);font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.1em;color:var(--muted);flex:1">SIZE&nbsp;&nbsp;D</span>
      <span style="padding:7px 13px;border-right:1px solid var(--frame);font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.1em;color:var(--muted);flex:1">SCALE&nbsp;&nbsp;1:1</span>
      <span style="padding:7px 13px;font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.1em;color:var(--muted);flex:1.2">SHEET 1 OF 1</span>
    </div>
    <div style="display:flex;align-items:center;justify-content:space-between;padding:7px 13px">
      <span style="font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.08em;color:var(--muted)">DWG&nbsp;&nbsp;HC-002</span>
      <a href="mailto:hello@hollow.rs" style="font:500 9px 'Spline Sans Mono',monospace;letter-spacing:.08em;color:var(--fg)">hello@hollow.rs</a>
    </div>
  </div>
</DrawingSheet>
